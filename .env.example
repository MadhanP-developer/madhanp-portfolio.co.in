# Contact-form lead pipeline — copy to .env for local dev,
# and add the same keys in Netlify → Project configuration → Environment variables.

# Supabase (Project Settings → Data API / API)
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Service-role key — SERVER-SIDE ONLY. Never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Apps Script Web App URL (Deploy → New deployment → Web app)
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXXXXXX/exec
